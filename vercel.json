{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/plataforma",
      "destination": "/platform/login.html"
    },
    {
      "source": "/app",
      "destination": "/platform/app.html"
    }
  ]
}
